{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "displayName": { "type": "string" },
        "isApproved": { "type": "boolean", "description": "Whether the user has been approved by admin" },
        "folderAccess": { 
          "type": "object", 
          "description": "Map of folder IDs to access status",
          "properties": {
            "linux": { "type": "boolean" },
            "shell": { "type": "boolean" },
            "jenkins": { "type": "boolean" },
            "aws": { "type": "boolean" },
            "docker": { "type": "boolean" },
            "kubernetes": { "type": "boolean" },
            "terraform": { "type": "boolean" },
            "argocd": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Meeting": {
      "title": "Educational Session",
      "description": "Represents a scheduled class or meeting.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "videoLink": { "type": "string", "description": "Google Drive video link" },
        "invitees": { "type": "array", "items": { "type": "string" }, "description": "List of user UIDs invited to this meeting" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "startTime", "endTime"]
    },
    "Attendance": {
      "title": "Student Attendance",
      "description": "Records student presence in a meeting.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "meetingId": { "type": "string" },
        "attended": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "meetingId", "attended"]
    },
    "Rating": {
      "title": "Session Feedback",
      "description": "Student ratings after a session.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "meetingId": { "type": "string" },
        "rating": { "type": "number" },
        "feedback": { "type": "string" }
      },
      "required": ["studentId", "meetingId", "rating"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message sent in community chat or announcements.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["text", "announcement"] }
      },
      "required": ["text", "senderId", "senderName", "timestamp", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/meetings/{meetingId}": {
      "schema": "Meeting",
      "description": "Scheduled classes and sessions"
    },
    "/meetings/{meetingId}/attendance/{studentId}": {
      "schema": "Attendance",
      "description": "Attendance records per meeting"
    },
    "/meetings/{meetingId}/ratings/{studentId}": {
      "schema": "Rating",
      "description": "Student feedback per session"
    },
    "/community_chat/{msgId}": {
      "schema": "ChatMessage",
      "description": "General community discussion messages"
    },
    "/announcements/{msgId}": {
      "schema": "ChatMessage",
      "description": "Official company announcements"
    },
    "/notifications/{notifId}": {
      "schema": "object",
      "description": "System notifications for users"
    },
    "/goals/{goalId}": {
      "schema": "object",
      "description": "Educational goals and milestones"
    },
    "/daily_challenges/{id}": {
      "schema": "object",
      "description": "Daily technical challenges"
    },
    "/activity/{id}": {
      "schema": "object",
      "description": "User activity logs"
    },
    "/published_videos/{id}": {
      "schema": "object",
      "description": "Videos in the course portal"
    },
    "/references/{id}": {
      "schema": "object",
      "description": "Educational reference materials"
    },
    "/assessments/{id}": {
      "schema": "object",
      "description": "Student assessments"
    },
    "/interview_prep/{id}": {
      "schema": "object",
      "description": "Interview preparation guides"
    },
    "/qa_questions/{id}": {
      "schema": "object",
      "description": "Q&A forum questions"
    },
    "/qa_answers/{id}": {
      "schema": "object",
      "description": "Q&A forum answers"
    },
    "/video_progress/{id}": {
      "schema": "object",
      "description": "Student progress on specific videos"
    }
  }
}
