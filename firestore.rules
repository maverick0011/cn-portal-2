rules_version = '2';

// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - role: string (required, 'admin' or 'student')
//   - displayName: string (optional)
//   - createdAt: string (optional)
//
// Collection: meetings
// Document ID: {meetingId}
// Fields:
//   - title: string (required)
//   - description: string (optional)
//   - startTime: string (required, ISO date string)
//   - endTime: string (required, ISO date string)
//   - videoLink: string (optional)
//   - createdBy: string (required, admin UID)
//
// Collection: meetings/{meetingId}/attendance/{studentId}
// Document ID: {studentId}
// Fields:
//   - studentId: string (required)
//   - meetingId: string (required)
//   - attended: bool (required)
//   - timestamp: string (required)
//
// Collection: meetings/{meetingId}/ratings/{studentId}
// Document ID: {studentId}
// Fields:
//   - studentId: string (required)
//   - meetingId: string (required)
//   - rating: number (required, 1-5)
//   - feedback: string (optional)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isEmailAdmin() {
      return isSignedIn() && request.auth.token.email_verified == true && (
        request.auth.token.email.lower() == "mavbharath01@gmail.com" || 
        request.auth.token.email.lower() == "admin@cnportal.com"
      );
    }

    function isAdmin() {
      return isEmailAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin'
      );
    }

    function isApproved() {
      return isEmailAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isApproved', false) == true
      );
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidUser(data) {
      return data.uid is string && 
             data.email is string &&
             data.role in ['admin', 'student'] &&
             data.keys().hasAll(['uid', 'email', 'role']) &&
             data.keys().size() >= 3;
    }

    function isValidActivity(data) {
      return data.userId is string && 
             data.text is string && 
             data.timestamp is string;
    }

    function isValidMessage(data) {
      return data.text is string && data.text.size() <= 1000 &&
             data.senderId is string &&
             data.senderName is string &&
             data.type in ['text', 'announcement'] &&
             data.keys().hasAll(['text', 'senderId', 'senderName', 'timestamp', 'type']) &&
             data.keys().size() == 5;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      // Allow a user to read their own profile
      allow get: if isOwner(userId);
      // Allow approved users or admins to read any profile
      allow get: if isApproved();
      
      // Only admins or approved users can list all users
      allow list: if isEmailAdmin() || isAdmin();
      
      // Ownership-based creation and updates
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isValidId(userId) && (
        isOwner(userId) || isAdmin()
      ) && (
        // Only admins can change roles or approval status
        (isAdmin()) || 
        (incoming().role == existing().role && incoming().isApproved == existing().isApproved)
      );
      allow delete: if isAdmin();
    }

    match /activity/{actId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidActivity(incoming());
    }

    match /goals/{goalId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid);
    }

    match /daily_challenges/{challengeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /messages/{msgId} {
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
    }

    match /community_chat/{msgId} {
      allow read: if isApproved();
      // Writing requires approved status AND verified email
      allow create: if isApproved() && isEmailVerified() && incoming().senderId == request.auth.uid && isValidMessage(incoming());
    }

    match /announcements/{msgId} {
      allow read: if isApproved();
      allow create: if isAdmin() && isEmailVerified() && isValidMessage(incoming());
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /published_videos/{videoId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /video_progress/{progressId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /references/{refId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /assessments/{aId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /interview_prep/{pId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /meetings/{meetingId} {
      allow read: if isApproved();
      allow write: if isAdmin();

      match /attendance/{studentId} {
        allow read: if isApproved();
        allow write: if isAdmin() || isOwner(studentId);
      }

      match /ratings/{studentId} {
        allow read: if isAdmin() || isOwner(studentId);
        allow write: if isAdmin() || isOwner(studentId);
      }
    }

    match /qa_questions/{qId} {
      allow read: if isApproved();
      allow create: if isApproved() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isApproved() && existing().userId == request.auth.uid);
    }

    match /qa_answers/{aId} {
      allow read: if isApproved();
      allow create: if isApproved() && incoming().userId == request.auth.uid;
      allow delete: if isAdmin() || (isApproved() && existing().userId == request.auth.uid);
    }

    // 0. Global Safety Net (Final fallback)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

